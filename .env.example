# Notion
NOTION_API_KEY=ntn_...
NOTION_DATABASE_ID=your-database-id

# Brightspace ICS calendar feed URL (from Brightspace > Calendar > Subscribe/Export)
BRIGHTSPACE_ICS_URL=https://<institution>.brightspace.com/d2l/le/calendar/feed/user/feed.ics?token=your-token
SYNC_DAYS_AHEAD=180

# Course mappings (JSON array, required)
COURSES_JSON=[{"course_label":"CS 101","brightspace_ou":"123456","gradescope_id":null},{"course_label":"MATH 201","brightspace_ou":"789012","gradescope_id":"345678"}]

# OpenClaw notifications (reads token/port from ~/.openclaw/openclaw.json by default)
OPENCLAW_ENABLED=1
# OPENCLAW_GATEWAY_URL=http://127.0.0.1:18789
# OPENCLAW_HOOKS_TOKEN=your-hooks-token
OPENCLAW_TELEGRAM_TO=your-telegram-user-id

# Polling interval for --watch mode (minutes)
POLL_INTERVAL_MINUTES=30

# Timezone
TZ=America/Indiana/Indianapolis
